# Smart Companion Environment Variables


GEMINI_API_KEY=your_actual_gemini_api_key_here


JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long-for-production-security

# ============================================
# OPTIONAL VARIABLES
# (Defaults shown below)
# ============================================

# Port Configuration

# FRONTEND_PORT=3000
# BACKEND_PORT=5000
# LLM_API_PORT=8000
# MONGODB_PORT=27017

# Node Environment
# NODE_ENV=production

# MongoDB Configuration
# MONGO_INITDB_DATABASE=smart-companion

# ============================================
# PRODUCTION DEPLOYMENT
# ============================================

# For production, consider:
# 1. Using MongoDB Atlas instead of local MongoDB
# 2. Setting up SSL/TLS certificates
# 3. Configuring proper firewall rules
# 4. Setting up monitoring and logging
# 5. Enabling auto-backups for MongoDB

# MongoDB Atlas (Optional - for production)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-companion

# ============================================

